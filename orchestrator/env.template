ANTHROPIC_API_KEY=your_anthropic_api_key_here
NOTION_API_URL=http://localhost:3001

# Ollama — local LLM inference (use container name when running in Docker)
OLLAMA_URL=http://ollama:11434

# Whisper — audio transcription service (use container name when running in Docker)
WHISPER_URL=http://whisper:9000

# Qdrant — vector database for semantic search (use container name when running in Docker)
QDRANT_URL=http://qdrant:6333

# TikTok — WSL host path to the video archive (used for path translation to container mount)
TIKTOK_VIDEOS_PATH=/mnt/m/TT videos/data

# Notion target routing databases
NOTION_PROJECTS_DATABASE_ID=your_projects_database_id_here
NOTION_KNOWLEDGE_DATABASE_ID=your_knowledge_database_id_here
NOTION_JOURNAL_DATABASE_ID=your_journal_database_id_here

# MySQL — workflow history database
# Leave MYSQL_HOST unset to run without persistence (dry-runs, local dev)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=orchestrator
MYSQL_PASSWORD=orchestrator
MYSQL_DATABASE=orchestrator
