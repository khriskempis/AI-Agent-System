{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Template Schema",
  "description": "Schema for validating n8n agent template configurations",
  "type": "object",
  "required": ["agent_metadata", "node_config"],
  "properties": {
    "agent_metadata": {
      "type": "object",
      "required": ["agent_type", "version", "last_tested", "status"],
      "properties": {
        "agent_type": {
          "type": "string",
          "enum": ["director", "notion", "validation", "planner", "custom"]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "last_tested": {
          "type": "string",
          "format": "date"
        },
        "tested_by": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["verified", "testing", "deprecated", "broken"]
        },
        "changelog": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "version": { "type": "string" },
              "date": { "type": "string", "format": "date" },
              "changes": { "type": "string" }
            }
          }
        }
      }
    },
    "node_config": {
      "type": "object",
      "required": ["name", "type", "parameters"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "parameters": {
          "type": "object"
        },
        "position": {
          "type": "array",
          "items": { "type": "number" },
          "minItems": 2,
          "maxItems": 2
        }
      }
    },
    "required_tools": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "object",
      "properties": {
        "services": {
          "type": "array",
          "items": { "type": "string" }
        },
        "models": {
          "type": "array", 
          "items": { "type": "string" }
        },
        "environment_variables": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "testing_info": {
      "type": "object",
      "properties": {
        "test_cases_passed": {
          "type": "array",
          "items": { "type": "string" }
        },
        "known_issues": {
          "type": "array",
          "items": { "type": "string" }
        },
        "performance_metrics": {
          "type": "object",
          "properties": {
            "avg_response_time_ms": { "type": "number" },
            "success_rate_percent": { "type": "number" }
          }
        }
      }
    }
  }
}
